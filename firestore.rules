rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to get the user's role and salonId from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Function to check roles
    function isSuperAdmin() {
      return request.auth != null && getUserData().role == 'superadmin';
    }
    function isAdmin() {
      return request.auth != null && getUserData().role == 'admin';
    }
    function isCustomer() {
      return request.auth != null && getUserData().role == 'customer';
    }
    
    // ─── USERS COLLECTION ───
    match /users/{userId} {
      // SuperAdmins can read/write all
      // Admins can read all users (for customer directory)
      // Users can read/write their own data
      allow read: if request.auth != null;
      allow write: if isSuperAdmin() || request.auth.uid == userId;
    }
    
    // ─── SALONS COLLECTION ───
    match /salons/{salonId} {
      // Anyone logged in can read salons
      allow read: if request.auth != null;
      // SuperAdmins can write all salons
      // Admins can only write their own salon
      allow write: if isSuperAdmin() || (isAdmin() && getUserData().salonId == salonId);
    }
    
    // ─── BOOKINGS COLLECTION ───
    match /bookings/{bookingId} {
      // SuperAdmins can read/write all bookings
      // Admins can read/write bookings where salonId matches their assigned salonId
      // Customers can read/write their own bookings
      allow read: if isSuperAdmin() 
                  || (isAdmin() && resource.data.salonId == getUserData().salonId) 
                  || (isCustomer() && resource.data.userId == request.auth.uid);
                  
      allow create: if isSuperAdmin() 
                    || (isAdmin() && request.resource.data.salonId == getUserData().salonId) 
                    || (isCustomer() && request.resource.data.userId == request.auth.uid);
                    
      allow update, delete: if isSuperAdmin() 
                            || (isAdmin() && resource.data.salonId == getUserData().salonId) 
                            || (isCustomer() && resource.data.userId == request.auth.uid);
    }
    
    // ─── ANNOUNCEMENTS COLLECTION ───
    match /announcements/{announcementId} {
      // Anyone logged in can read announcements
      allow read: if request.auth != null;
      // Only SuperAdmins can create/update/delete announcements
      allow write: if isSuperAdmin();
    }
    
    // ─── AUDIT LOGS COLLECTION ───
    match /auditLogs/{logId} {
      // Only SuperAdmins can read audit logs
      allow read: if isSuperAdmin();
      // Anyone can create an audit log
      allow create: if request.auth != null;
      // No one can update or delete audit logs
      allow update, delete: if false;
    }
  }
}
